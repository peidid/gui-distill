# env
.venv/
__pycache__/
*.pyc

# data & outputs (big / regenerable — never commit)
data/
out/
results/*.png
*.tfrecord
*.parquet

# model weights / adapters / big bundles (keep local; git is not for large binaries)
*.safetensors
*.bin
*.tar.gz
*.zip

# keep folder structure
!data/.gitkeep
!out/.gitkeep
!results/.gitkeep

# os
.DS_Store
